    <string name="privacy_policy_title">गोपनीयता नीति</string>
    <string name="privacy_policy_intro">हम आपकी गोपनीयता का महत्व समझते हैं। कृपया X Player का उपयोग करने के लिए हमारी नीति की समीक्षा करें और स्वीकार करें।</string>
    <string name="privacy_policy_permissions_title">अनुमतियों का उपयोग:</string>
